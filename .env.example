# ==================================================
# Resume AI Pipeline
# Environment Configuration
# ==================================================

# --------------------------------------------------
# LLM Provider
# --------------------------------------------------

LLM_PROVIDER=GEMINI

# --------------------------------------------------
# Google Gemini
# --------------------------------------------------

GEMINI_API_KEY=YOUR_GEMINI_API_KEY

GEMINI_MODEL=gemini-2.5-flash

# --------------------------------------------------
# OpenAI
# --------------------------------------------------

OPENAI_API_KEY=

OPENAI_MODEL=gpt-5

# --------------------------------------------------
# Generation
# --------------------------------------------------

TEMPERATURE=0.2

MAX_TOKENS=4000

# --------------------------------------------------
# Logging
# --------------------------------------------------

LOG_LEVEL=INFO